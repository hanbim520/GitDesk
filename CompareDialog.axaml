<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GitDesk.CompareDialog"
        Title="Compare"
        Width="1480"
        Height="860"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />

        <SolidColorBrush x:Key="CompareContentBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CompareLineNumberBackgroundBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="CompareAddedBackgroundBrush" Color="#DDF4DD" />
        <SolidColorBrush x:Key="CompareDeletedBackgroundBrush" Color="#FFE1E1" />
        <SolidColorBrush x:Key="CompareModifiedLeftBackgroundBrush" Color="#FFF4C2" />
        <SolidColorBrush x:Key="CompareModifiedRightBackgroundBrush" Color="#E0F5D7" />
        <SolidColorBrush x:Key="CompareAddedLineNumberBackgroundBrush" Color="#D3ECD3" />
        <SolidColorBrush x:Key="CompareDeletedLineNumberBackgroundBrush" Color="#F4D4D4" />
        <SolidColorBrush x:Key="CompareModifiedLeftLineNumberBackgroundBrush" Color="#F0E6AF" />
        <SolidColorBrush x:Key="CompareModifiedRightLineNumberBackgroundBrush" Color="#D3EACB" />
        <SolidColorBrush x:Key="CompareAddedMarkerBrush" Color="#83C783" />
        <SolidColorBrush x:Key="CompareDeletedMarkerBrush" Color="#D99595" />
        <SolidColorBrush x:Key="CompareModifiedMarkerBrush" Color="#C8BE65" />

    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.code">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-marker">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-marker.added">
            <Setter Property="Background" Value="{DynamicResource CompareAddedMarkerBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-marker.deleted">
            <Setter Property="Background" Value="{DynamicResource CompareDeletedMarkerBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-marker.modified">
            <Setter Property="Background" Value="{DynamicResource CompareModifiedMarkerBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-number">
            <Setter Property="Background" Value="{DynamicResource CompareLineNumberBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-number.added">
            <Setter Property="Background" Value="{DynamicResource CompareAddedLineNumberBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-number.deleted">
            <Setter Property="Background" Value="{DynamicResource CompareDeletedLineNumberBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-number.modified-left">
            <Setter Property="Background" Value="{DynamicResource CompareModifiedLeftLineNumberBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-number.modified-right">
            <Setter Property="Background" Value="{DynamicResource CompareModifiedRightLineNumberBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-content">
            <Setter Property="Background" Value="{DynamicResource CompareContentBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-content.added">
            <Setter Property="Background" Value="{DynamicResource CompareAddedBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-content.deleted">
            <Setter Property="Background" Value="{DynamicResource CompareDeletedBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-content.modified-left">
            <Setter Property="Background" Value="{DynamicResource CompareModifiedLeftBackgroundBrush}" />
        </Style>
        <Style Selector="ItemsControl.compare-lines Border.line-content.modified-right">
            <Setter Property="Background" Value="{DynamicResource CompareModifiedRightBackgroundBrush}" />
        </Style>
        <Style Selector="DataGrid.compare-grid">
            <Setter Property="Background" Value="{DynamicResource CompareContentBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="RowHeight" Value="22" />
            <Setter Property="HeadersVisibility" Value="None" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Styles>

    <DockPanel Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <Menu DockPanel.Dock="Top" FontSize="12" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="Close" Click="OnCloseClicked" />
            </MenuItem>
            <MenuItem Header="_Edit" />
            <MenuItem Header="_View" />
            <MenuItem Header="_Search" />
            <MenuItem Header="_Help" />
        </Menu>

        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button Classes="toolbar" Content="R" ToolTip.Tip="Refresh compare view" Click="OnRefreshClicked" />
                <Button Classes="toolbar" Content="S" ToolTip.Tip="Save diff as patch" Click="OnSavePatchClicked" />
                <Button Classes="toolbar" Content="CL" ToolTip.Tip="Copy left content" Click="OnCopyLeftContentClicked" />
                <Button Classes="toolbar" Content="CR" ToolTip.Tip="Copy right content" Click="OnCopyRightContentClicked" />
                <Button Classes="toolbar" Content="CA" ToolTip.Tip="Copy all compare content" Click="OnCopyAllContentClicked" />
                <TextBlock Text="|" Margin="8,0" VerticalAlignment="Center"                            Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <Button Classes="toolbar" Content="U" ToolTip.Tip="Undo is not available in read-only compare" IsEnabled="False" />
                <Button Classes="toolbar" Content="D" ToolTip.Tip="Redo is not available in read-only compare" IsEnabled="False" />
                <TextBlock Text="-" Margin="8,0" VerticalAlignment="Center"                            Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <Button Classes="toolbar" Content="|&lt;" ToolTip.Tip="First difference" Click="OnFirstDifferenceClicked" />
                <Button Classes="toolbar" Content="&lt;" ToolTip.Tip="Previous difference" Click="OnPreviousDifferenceClicked" />
                <Button Classes="toolbar" Content="&gt;" ToolTip.Tip="Next difference" Click="OnNextDifferenceClicked" />
                <Button Classes="toolbar" Content="&gt;|" ToolTip.Tip="Last difference" Click="OnLastDifferenceClicked" />
                <TextBlock Text="-" Margin="8,0" VerticalAlignment="Center"                            Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBox x:Name="FindTextBox"
                         Width="180"
                         Height="25"
                         PlaceholderText="Find"
                         FontSize="12"
                         KeyDown="OnFindTextBoxKeyDown" />
                <Button Classes="toolbar" Content="FP" ToolTip.Tip="Find previous" Click="OnFindPreviousClicked" />
                <Button Classes="toolbar" Content="FN" ToolTip.Tip="Find next" Click="OnFindNextClicked" />
                <TextBlock Text="|" Margin="8,0" VerticalAlignment="Center"                            Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <Button Classes="toolbar" Content="LN" ToolTip.Tip="Line numbers are always shown" IsEnabled="False" />
                <Button Classes="toolbar" Content="DI" ToolTip.Tip="Differences are highlighted in the editor" IsEnabled="False" />
                <TextBlock Text="{Binding StatusModeText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Padding="7,3">
            <TextBlock Text="{Binding SummaryText}" FontSize="12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>

        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,5,*">
            <Border Grid.Row="0"
                    Grid.Column="0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,1"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Padding="7,3">
                <Grid ColumnDefinitions="14,*">
                    <Ellipse Grid.Column="0"
                             Width="12"
                             Height="12"
                             Fill="{DynamicResource AccentFillColorDefaultBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding LeftHeaderText}"
                               FontFamily="Consolas, Cascadia Mono, Courier New"
                               FontSize="12"
                               Margin="6,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <Border Grid.Row="0"
                    Grid.Column="2"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,1"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Padding="7,3">
                <Grid ColumnDefinitions="14,*">
                    <Ellipse Grid.Column="0"
                             Width="12"
                             Height="12"
                             Fill="{DynamicResource SystemFillColorSuccessBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RightHeaderText}"
                               FontFamily="Consolas, Cascadia Mono, Courier New"
                               FontSize="12"
                               Margin="6,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer x:Name="LeftCompareScrollViewer"
                          Grid.Row="1"
                          Grid.Column="0"
                          Background="{DynamicResource CompareContentBackgroundBrush}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl Classes="compare-lines" ItemsSource="{Binding Lines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="22"
                                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="8,50,Auto">
                                    <Border Grid.Column="0" Classes.line-marker="True" Classes.deleted="{Binding IsDeleted}" Classes.modified="{Binding IsModified}" />
                                    <Border Grid.Column="1"
                                            Classes.line-number="True"
                                            Classes.deleted="{Binding IsDeleted}"
                                            Classes.modified-left="{Binding IsModified}"
                                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,1,0"
                                            Padding="2,0">
                                        <TextBlock Classes="code"
                                                   Text="{Binding LeftLineNumber}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextAlignment="Right" />
                                    </Border>
                                    <Border Grid.Column="2"
                                            MinWidth="720"
                                            Classes.line-content="True"
                                            Classes.deleted="{Binding IsDeleted}"
                                            Classes.modified-left="{Binding IsModified}"
                                            Padding="6,0">
                                        <TextBlock Classes="code"
                                                   Text="{Binding LeftText}"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <GridSplitter Grid.Row="1"
                          Grid.Column="1"
                          Width="5"
                          Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                          ResizeDirection="Columns" />

            <ScrollViewer x:Name="RightCompareScrollViewer"
                          Grid.Row="1"
                          Grid.Column="2"
                          Background="{DynamicResource CompareContentBackgroundBrush}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl Classes="compare-lines" ItemsSource="{Binding Lines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="22"
                                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="8,50,Auto">
                                    <Border Grid.Column="0" Classes.line-marker="True" Classes.added="{Binding IsAdded}" Classes.modified="{Binding IsModified}" />
                                    <Border Grid.Column="1"
                                            Classes.line-number="True"
                                            Classes.added="{Binding IsAdded}"
                                            Classes.modified-right="{Binding IsModified}"
                                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,1,0"
                                            Padding="2,0">
                                        <TextBlock Classes="code"
                                                   Text="{Binding RightLineNumber}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextAlignment="Right" />
                                    </Border>
                                    <Border Grid.Column="2"
                                            MinWidth="720"
                                            Classes.line-content="True"
                                            Classes.added="{Binding IsAdded}"
                                            Classes.modified-right="{Binding IsModified}"
                                            Padding="6,0">
                                        <TextBlock Classes="code"
                                                   Text="{Binding RightText}"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
